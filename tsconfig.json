{
  "compilerOptions": {
    "outDir": "./dist",
    "module": "ES6",
    "target": "ES2019",
    "esModuleInterop": true,
    "sourceMap": true,
    "rootDirs": ["src"],
    "baseUrl": "src",
    "strict": true,
    "paths": {
      "@/tests/*": ["../tests/*"],
      "@/*": ["*"]
    }
  },
  "include": ["src", "tests"],
  "exclude": ["./node_modules"]
}
